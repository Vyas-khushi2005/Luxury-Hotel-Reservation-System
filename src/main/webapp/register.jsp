<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>User Registration</title>

<link rel="stylesheet" href="css/style.css">

</head>
<body>

<div class="register-page">

<div class="register-card">

<h1>Luxury Hotel</h1>

<h2>Create Account</h2>

<form action="register" method="post">

<input type="text"
name="name"
placeholder="Enter Full Name"
required>

<input type="email"
name="email"
placeholder="Enter Email"
required>

<input type="password"
name="password"
placeholder="Enter Password"
required>

<button type="submit">
Register
</button>

</form>

<p class="login-link">

Already have an account?

<a href="login.jsp">
Login Here
</a>

</p>

</div>

</div>

</body>
</html>